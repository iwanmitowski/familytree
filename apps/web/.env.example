# Vercel / web environment (idea.md §17, §20). Copy to .env.local for dev.
# NO secret may be prefixed NEXT_PUBLIC_ — only the Turnstile site key is public.

# Oracle API (BFF → API)
ORACLE_API_BASE_URL=
SERVICE_ID=
SERVICE_HMAC_SECRET=
IP_HASH_SECRET=

# Cloudflare Turnstile (anti-bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Admin authentication (Auth.js)
AUTH_SECRET=
ADMIN_EMAIL_ALLOWLIST=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
