# Oracle VM environment for infra/oracle/docker-compose.prod.yml.
# Copy to `.env` on the VM (chmod 600) and fill in real values. Never commit .env.
# Всички стойности по-долу са примерни — заменете ги с реални при разгръщане.

# --- Container image (set by the deploy workflow to the commit SHA) ---
API_IMAGE=ghcr.io/iwanmitowski/familytree-api:latest

# --- PostgreSQL superuser (used only for init + admin) ---
# Суперпотребител — използва се само при инициализация; приложението НЕ го ползва.
POSTGRES_SUPER_USER=familytree_admin
POSTGRES_SUPER_PASSWORD=change-me-superuser-password
POSTGRES_DB=familytree

# --- Application database role (least privilege; the API connects as this) ---
# Роля на приложението с минимални права — API-то се свързва само с нея.
APP_DB_USER=familytree_app
APP_DB_PASSWORD=change-me-app-password

# --- HMAC service auth (MUST match the Vercel SERVICE_ID / SERVICE_HMAC_SECRET) ---
# Трябва да съвпадат със стойностите във Vercel.
SERVICE_ID=familytree-bff
SERVICE_HMAC_SECRET=change-me-64-hex-shared-secret

# --- Domain / TLS ---
API_DOMAIN=api.rod.mitovski.example

# --- Logging ---
LOG_LEVEL=info

# --- Timezone ---
TZ=Europe/Sofia
