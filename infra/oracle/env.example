# Oracle VM environment for infra/oracle/docker-compose.prod.yml.
# Copy to `.env` on the VM (chmod 600) and fill in real values. Never commit .env.
# Всички стойности по-долу са примерни — заменете ги с реални при разгръщане.

# --- Container image (set by the deploy workflow to the commit SHA) ---
API_IMAGE=ghcr.io/iwanmitowski/familytree-api:latest

# --- PostgreSQL superuser (used only for init + admin) ---
# Суперпотребител — използва се само при инициализация; приложението НЕ го ползва.
POSTGRES_SUPER_USER=familytree_admin
POSTGRES_SUPER_PASSWORD=change-me-superuser-password
POSTGRES_DB=familytree

# --- Application database role (least privilege; the API connects as this) ---
# Роля на приложението с минимални права — API-то се свързва само с нея.
APP_DB_USER=familytree_app
APP_DB_PASSWORD=change-me-app-password

# --- HMAC service auth (MUST match the Vercel SERVICE_ID / SERVICE_HMAC_SECRET) ---
# Трябва да съвпадат със стойностите във Vercel.
SERVICE_ID=familytree-bff
SERVICE_HMAC_SECRET=change-me-64-hex-shared-secret

# --- Domain / TLS ---
API_DOMAIN=api.rod.mitovski.example

# --- Logging ---
LOG_LEVEL=info

# --- Timezone ---
TZ=Europe/Sofia

# --- Backups (idea.md §21) ---
# age PUBLIC key (encryption). Частният ключ се пази ОФЛАЙН, извън VM-а.
AGE_RECIPIENT=age1exampleexampleexampleexampleexampleexampleexampleex
# По избор: втори (VM-локален) age получател + неговият частен ключ, за да може
# месечният verify-backup.sh да прави ПЪЛЕН restore тест без офлайн ключа.
# Оставете празни, за да е само lightweight проверка (изтегляне + checksum).
AGE_VERIFY_RECIPIENT=
AGE_VERIFY_IDENTITY_FILE=
# rclone remotes (configure with `rclone config` on the VM).
RCLONE_REMOTE_PRIMARY=oci:familytree-backups
RCLONE_REMOTE_SECONDARY=r2:familytree-backups
BACKUP_DIR=/opt/familytree/backups
RETAIN_DAILY=14
RETAIN_WEEKLY=8
RETAIN_MONTHLY=12
# Optional alerting for backup/verify/disk jobs and the metrics gauge path.
NOTIFY_WEBHOOK_URL=
BACKUP_STATUS_PATH=/opt/familytree/backups/backup-status.json

# --- Uploaded files (idea.md §24 Phase 6) ---
# Host path bind-mounted into the API at /app/file-storage; synced off-box by
# backup-db.sh. Keep on the block volume, not the boot disk.
FILE_STORAGE_DIR=/opt/familytree/file-storage
