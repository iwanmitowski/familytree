# Local development values. Copy to .env (gitignored) and adjust if needed.
DATABASE_URL=postgres://familytree:familytree@localhost:5433/familytree_dev
PORT=8080
LOG_LEVEL=info
ENV=dev
# HMAC service auth (contracts/hmac.md). Dev-only values — production secrets
# are generated per-deploy and never committed.
