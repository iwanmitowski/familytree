{
  "name": "@familytree/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && node esbuild.config.mjs",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate:up": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "migrate:status": "tsx src/db/migrate.ts status",
    "codegen": "kysely-codegen --out-file src/db/generated/db.ts"
  },
  "dependencies": {
    "@familytree/shared": "*",
    "@hono/node-server": "^2.0.10",
    "dotenv": "^17.4.2",
    "hono": "^4.12.31",
    "kysely": "^0.29.4",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.1",
    "kysely-codegen": "^0.20.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1"
  }
}
