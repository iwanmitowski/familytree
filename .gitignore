# ---- Secrets & environment ----
# Never commit real env files. Only *.example templates are tracked.
.env
.env.*
!.env.example
!env.example
*.env
!example.env

# Encryption / backup artifacts
*.age
*.dump
*.sql.gz
*.tar.gz

# ---- Node / Next.js (apps/web) ----
node_modules/
.next/
out/
build/
.turbo/
coverage/
*.tsbuildinfo
.eslintcache
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- API build output (services/api) ----
# Compiled/bundled output. NOTE: src/db/generated (kysely-codegen types) IS committed.
/services/api/dist/
/services/api/build/

# ---- Playwright / E2E ----
/apps/web/playwright-report/
/apps/web/test-results/
/apps/web/.playwright/

# ---- Docker ----
docker-compose.override.yml
docker-compose.*.override.yml

# ---- IDE / OS ----
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---- Local scratch ----
/tmp/
/.scratch/
